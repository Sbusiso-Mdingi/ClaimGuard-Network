{
  "name": "@claimguard/api",
  "private": true,
  "type": "module",
  "dependencies": {
    "@claimguard/shared-schema": "workspace:*",
    "@claimguard/database": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "@sentry/node": "^8.0.0",
    "@trpc/server": "^11.0.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.0.0",
    "newrelic": "^11.0.0",
    "zod": "^3.24.0"
  },
  "scripts": {
    "build": "mkdir -p dist && cp src/*.js src/*.cjs dist/",
