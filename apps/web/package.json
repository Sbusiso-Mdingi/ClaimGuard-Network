{
  "name": "@claimguard/web",
  "private": true,
  "type": "module",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@sentry/react": "^7.0.0"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "vitest": "^0.34.6",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/user-event": "^14.4.3",
    "jsdom": "^22.1.0"
  },
  "scripts": {
    "dev": "cd src && vite",
    "build": "cd src && vite build --outDir ../dist --emptyOutDir",
    "lint": "node --check src/server.js && node --check src/sentry-smoke.js",
    "serve": "node src/server.js",
    "test": "vitest --run"
  }
